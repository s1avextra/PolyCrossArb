[Unit]
Description=PolyCrossArb arb pipeline
After=network-online.target

[Service]
Type=simple
User=polycrossarb
WorkingDirectory=/opt/polycrossarb
EnvironmentFile=/opt/polycrossarb/.env
ExecStart=/usr/local/bin/uv run python scripts/run_arb.py --mode paper
Restart=on-failure
RestartSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
