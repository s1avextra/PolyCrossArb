# ── Polymarket API credentials ────────────────────────────────────
# Required for live trading. Paper trading works without these.
# Generate with: python scripts/derive_api_keys.py
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# ── Wallet (live execution only) ──────────────────────────────────
# Private key of a Polygon wallet funded with USDC.e.
# NEVER commit this file with a real key. Use a dedicated trading wallet.
PRIVATE_KEY=
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/84842078b09946638c03157f83405213

# ── Capital & risk ────────────────────────────────────────────────
# BANKROLL_USD=0 means auto-detect from wallet USDC.e balance.
# Set a specific value to override (e.g. if you want to use less than full balance).
BANKROLL_USD=0
MAX_TOTAL_EXPOSURE_USD=80.0       # ignored when bankroll is auto-detected (uses 80% of bankroll)
MAX_POSITION_PER_MARKET_USD=20.0  # max per event group (scales with bankroll)

# ── Arb detection ─────────────────────────────────────────────────
MIN_ARB_MARGIN=0.02
MIN_PROFIT_USD=0.10
SCAN_INTERVAL_SECONDS=30
COOLDOWN_SECONDS=120
