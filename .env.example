# ── Polymarket API credentials ────────────────────────────────────
# Generate with: python scripts/derive_api_keys.py
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# ── Wallet ────────────────────────────────────────────────────────
PRIVATE_KEY=
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_KEY

# ── Capital & risk ────────────────────────────────────────────────
# 0 = auto-detect from wallet USDC.e balance
BANKROLL_USD=0
MAX_TOTAL_EXPOSURE_USD=80.0
MAX_POSITION_PER_MARKET_USD=20.0

# ── Strategy: arb detection ───────────────────────────────────────
MIN_ARB_MARGIN=0.02
MIN_PROFIT_USD=0.10
SCAN_INTERVAL_SECONDS=30
COOLDOWN_SECONDS=120
MAX_RESOLUTION_DAYS=3
ONLY_OVERPRICED=true
KELLY_FRACTION=0.25

# ── Strategy: safety limits ───────────────────────────────────────
MAX_LEGS_PER_TRADE=4
MIN_LEG_PROBABILITY=0.05
MIN_LEG_BID_DEPTH_USD=50
MIN_LEG_VALUE_USD=5.0
MIN_LEG_VOLUME_USD=500

# ── Strategy: weather ─────────────────────────────────────────────
MIN_WEATHER_CONFIDENCE=0.80
MAX_WEATHER_POSITION_PCT=0.15

# ── Strategy: crypto ──────────────────────────────────────────────
MIN_CRYPTO_EDGE=0.03
MAX_CRYPTO_POSITION_PCT=0.10

# ── Candle: terminal zone (Phase 1) ──────────────────────────────
CANDLE_ZONE_TERMINAL_MIN_CONFIDENCE=0.55
CANDLE_ZONE_TERMINAL_MIN_Z=0.3
CANDLE_ZONE_TERMINAL_MIN_EDGE=0.03

# ── Candle: volatility regime sizing (Phase 1) ───────────────────
CANDLE_VOL_HIGH_MULTIPLIER=1.5
CANDLE_VOL_EXTREME_MULTIPLIER=2.0

# ── Candle: cross-asset lead-lag (Phase 2) ───────────────────────
CANDLE_CROSS_ASSET_ENABLED=0
CANDLE_CROSS_ASSET_MIN_CORRELATION=0.70
CANDLE_CROSS_ASSET_CONFIDENCE_BOOST=0.10

# ── Rust engine IPC (Phase 3) ────────────────────────────────────
IPC_MODE=stdin
IPC_SOCKET_PATH=/tmp/polycrossarb/engine.sock
CLOB_DIRECT=0

# ── Candle: maker fee optimization (Phase 4) ─────────────────────
CANDLE_PREFER_MAKER=0
CANDLE_MAKER_TIMEOUT_S=3

# ── Latency alerting (Phase 5) ───────────────────────────────────
LATENCY_ALERT_P99_MS=20
