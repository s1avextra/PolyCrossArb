# ── Polymarket API credentials ────────────────────────────────────
# Required for live trading (Phase 5). Paper trading works without these.
# Get them at: https://polymarket.com → Profile → API Keys
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# ── Wallet (live execution only) ──────────────────────────────────
# Private key of a Polygon wallet funded with USDC.
# NEVER commit this file with a real key. Use a dedicated trading wallet.
PRIVATE_KEY=
POLYGON_RPC_URL=https://polygon-rpc.com

# ── Capital & risk (adjust to your bankroll) ──────────────────────
BANKROLL_USD=100.0
MAX_TOTAL_EXPOSURE_USD=80.0
MAX_POSITION_PER_MARKET_USD=20.0

# ── Arb detection ─────────────────────────────────────────────────
MIN_ARB_MARGIN=0.02
MIN_PROFIT_USD=0.10
SCAN_INTERVAL_SECONDS=30
COOLDOWN_SECONDS=120
