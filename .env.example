# ── Polymarket API credentials ────────────────────────────────────
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# ── Wallet ────────────────────────────────────────────────────────
PRIVATE_KEY=
POLYGON_RPC_URL=https://polygon-rpc.com

# ── Capital & risk ────────────────────────────────────────────────
# 0 = auto-detect from wallet USDC.e balance
BANKROLL_USD=0
MAX_TOTAL_EXPOSURE_USD=80.0
MAX_POSITION_PER_MARKET_USD=20.0
COOLDOWN_SECONDS=120
KELLY_FRACTION=0.25

# ── Candle strategy ───────────────────────────────────────────────
MIN_CRYPTO_EDGE=0.03
MAX_CRYPTO_POSITION_PCT=0.10

# ── Candle zone gates (four-zone entry: early/primary/late/terminal) ──
CANDLE_ZONE_EARLY_MIN_CONFIDENCE=0.55
CANDLE_ZONE_EARLY_MIN_Z=2.0
CANDLE_ZONE_EARLY_MIN_EDGE=0.03
CANDLE_ZONE_PRIMARY_MIN_Z=1.0
CANDLE_ZONE_LATE_MIN_CONFIDENCE=0.65
CANDLE_ZONE_LATE_MIN_Z=0.5
CANDLE_ZONE_LATE_MIN_EDGE=0.08
CANDLE_ZONE_TERMINAL_MIN_CONFIDENCE=0.55
CANDLE_ZONE_TERMINAL_MIN_Z=0.3
CANDLE_ZONE_TERMINAL_MIN_EDGE=0.03
CANDLE_NOISE_Z_THRESHOLD=0.3

# ── Candle volatility regime sizing ──────────────────────────────
CANDLE_VOL_HIGH_MULTIPLIER=1.5
CANDLE_VOL_EXTREME_MULTIPLIER=2.0

# ── Candle cross-asset lead-lag ──────────────────────────────────
CANDLE_CROSS_ASSET_ENABLED=0
CANDLE_CROSS_ASSET_MIN_CORRELATION=0.70
CANDLE_CROSS_ASSET_CONFIDENCE_BOOST=0.10

# ── Candle maker fee optimization ────────────────────────────────
CANDLE_PREFER_MAKER=0
CANDLE_MAKER_TIMEOUT_S=3

# ── Candle circuit breaker ───────────────────────────────────────
CANDLE_BREAKER_MIN_TRADES=20
CANDLE_BREAKER_MIN_WIN_RATE=0.65
CANDLE_BREAKER_MAX_DRAWDOWN_PCT=0.30

# ── Alerter (required in live mode) ──────────────────────────────
ALERT_WEBHOOK_URL=
ALERT_CHANNEL=slack
ALERT_REQUIRED=0

# ── Rust engine IPC ──────────────────────────────────────────────
IPC_MODE=stdin
IPC_SOCKET_PATH=/tmp/polymomentum/engine.sock
CLOB_DIRECT=0

# ── Operational kill switch ──────────────────────────────────────
KILL_SWITCH_PATH=/tmp/polymomentum/KILL

# ── Latency alerting ─────────────────────────────────────────────
LATENCY_ALERT_P99_MS=200
